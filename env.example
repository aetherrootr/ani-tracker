# Copy this file to .env before running docker compose.

# Public application entrypoint.
APP_PORT=8080
CORS_ORIGIN=http://localhost:8080

# Flask session settings.
SECRET_KEY=change-me-to-a-long-random-secret
SESSION_COOKIE_SAMESITE=Lax
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=120
TRUST_PROXY=false
TZ=UTC
ANIME_TRACKER_INSTANCE_PATH=/var/lib/ani-tracker

# Per-user background image collection limits.
USER_WALLPAPER_MAX_IMAGES_PER_USER=12
USER_WALLPAPER_MAX_BYTES=10485760

# PostgreSQL.
POSTGRES_DB=ani_tracker
POSTGRES_USER=ani_tracker
POSTGRES_PASSWORD=ani_tracker_change_me

# Optional anime metadata provider credentials.
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=
TMDB_INCLUDE_ADULT=false
TVDB_API_KEY=
TVDB_PIN=
PROVIDER_UPDATES_ENABLED=true
PROVIDER_UPDATES_INTERVAL_SECONDS=900
PROVIDER_UPDATES_INITIAL_LOOKBACK_SECONDS=3600
PROVIDER_UPDATES_OVERLAP_SECONDS=600
PROVIDER_UPDATES_LEASE_SECONDS=600
PROVIDER_UPDATES_SAFETY_LAG_SECONDS=60
PROVIDER_UPDATES_MAX_PAGES=10
TVDB_STATUS_AIR_TIME_BACKFILL_BATCH_SIZE=10
IMPORT_PROVIDER_TIMEOUT=5

# Incremental providers are reconciled daily; other providers sync every four hours.
# Episode aired status is updated locally every minute.
ANIME_SYNC_CRON_HOUR=4
ANIME_SYNC_CRON_MINUTE=0
NON_INCREMENTAL_ANIME_SYNC_CRON_HOUR=0,4,8,12,16,20
NON_INCREMENTAL_ANIME_SYNC_CRON_MINUTE=0
EPISODE_STATUS_REFRESH_INTERVAL_SECONDS=60

# Optional automatic related-anime imports.
UNTRACKED_ANIME_CLEANUP_DISABLED=true
UNTRACKED_ANIME_CLEANUP_CRON_MONTHS=
UNTRACKED_ANIME_CLEANUP_CRON_DAY=
UNTRACKED_ANIME_CLEANUP_CRON_HOUR=
UNTRACKED_ANIME_CLEANUP_CRON_MINUTE=
AUTO_IMPORT_TVDB_SEASONS_ENABLED=false
AUTO_IMPORT_TVDB_SEASONS_CRON_DAY=
AUTO_IMPORT_TVDB_SEASONS_CRON_HOUR=
AUTO_IMPORT_TVDB_SEASONS_CRON_MINUTE=
AUTO_IMPORT_BANGUMI_RELATED_ANIME_ENABLED=false
AUTO_IMPORT_BANGUMI_RELATED_ANIME_CRON_DAY=
AUTO_IMPORT_BANGUMI_RELATED_ANIME_CRON_HOUR=
AUTO_IMPORT_BANGUMI_RELATED_ANIME_CRON_MINUTE=

# Optional OIDC / SSO.
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile
