# Copy this file to .env before running docker compose.

# Public application entrypoint.
APP_PORT=8080
CORS_ORIGIN=http://localhost:8080

# Flask session settings.
SECRET_KEY=change-me-to-a-long-random-secret
SESSION_COOKIE_SAMESITE=Lax
WEB_CONCURRENCY=2
TRUST_PROXY=false
TZ=UTC

# PostgreSQL.
POSTGRES_DB=ani_tracker
POSTGRES_USER=ani_tracker
POSTGRES_PASSWORD=ani_tracker_change_me

# Optional anime metadata provider credentials.
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=
TMDB_INCLUDE_ADULT=false
TVDB_API_KEY=
TVDB_PIN=

# Optional OIDC / SSO.
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile
