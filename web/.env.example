# Optional. Leave unset in local dev to use the Next.js /api proxy.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional server-side proxy target for Next.js rewrites.
# API_PROXY_TARGET=http://127.0.0.1:3001

# Optional. Set by launch_dev_service.sh --lan to allow LAN dev websocket origins.
# ENABLE_LAN_DEV=1
